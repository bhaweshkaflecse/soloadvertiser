# Solo Advertiser — Environment Configuration
# Copy this file to .env and fill in values.

# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://soloadvertiser:devpassword@localhost:5432/soloadvertiser

# Redis
REDIS_URL=redis://localhost:6379

# Authentication (placeholder)
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRY=24h

# Logging
LOG_LEVEL=debug

# External Services (placeholder)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# S3_BUCKET=soloadvertiser-uploads

# Payment (placeholder)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# Push Notifications (placeholder)
# FIREBASE_PROJECT_ID=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_CLIENT_EMAIL=

# Google OAuth
GOOGLE_CLIENT_ID_WEB=your-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID_MOBILE=your-mobile-client-id.apps.googleusercontent.com
