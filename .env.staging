# Staging Environment
NODE_ENV=staging
DATABASE_URL=postgresql://postgres:${DB_PASSWORD}@postgres:5432/soloadvertiser_staging
REDIS_URL=redis://redis:6379
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
R2_ENDPOINT=${R2_ENDPOINT}
R2_ACCESS_KEY=${R2_ACCESS_KEY}
R2_SECRET_KEY=${R2_SECRET_KEY}
R2_BUCKET=soloadvertiser-staging
PORT=3000
CORS_ORIGINS=https://staging-admin.soloadvertiser.com,https://staging-business.soloadvertiser.com
LOG_LEVEL=info
