  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0"
  },
  "devDependencies": {
    "@soloadvertiser/tsconfig": "workspace:*",
    "prisma": "^5.10.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
