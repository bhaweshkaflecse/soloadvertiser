// Prisma Schema — Solo Advertiser
// Sprint 1: Identity, Configuration, and Media models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === IDENTITY MODULE (CTX-001) ===

enum Role {
  SUPER_ADMIN
  ADMIN
  OPERATIONS_STAFF
  FINANCE_STAFF
  BUSINESS
  RIDER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

model User {
  id             String     @id @default(uuid()) @db.Uuid
  email          String?    @unique
  phone          String?    @unique
  passwordHash   String?    @map("password_hash")
  role           Role       @default(RIDER)
  status         UserStatus @default(ACTIVE)
  emailVerified  Boolean    @default(false) @map("email_verified")
  phoneVerified  Boolean    @default(false) @map("phone_verified")
  failedAttempts Int        @default(0) @map("failed_attempts")
  lockedUntil    DateTime?  @map("locked_until")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  sessions Session[]

  @@map("identity_users")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  deviceInfo   String?  @map("device_info")
  ipAddress    String?  @map("ip_address")
  refreshToken String   @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("identity_sessions")
}

// === CONFIGURATION MODULE (CTX-009) ===

model ConfigEntry {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  value       Json
  category    String
  description String?
  dataType    String   @map("data_type")
  updatedBy   String?  @map("updated_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("config_entries")
}

model FeatureFlag {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?
  updatedBy   String?  @map("updated_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("config_feature_flags")
}

model DictionaryItem {
  id          String   @id @default(uuid()) @db.Uuid
  dictionary  String
  code        String
  label       String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  metadata    Json?
  regionId    String?  @map("region_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([dictionary, code])
  @@map("config_dictionary_items")
}

// === MEDIA MODULE (CTX-012) ===

model MediaAsset {
  id         String    @id @default(uuid()) @db.Uuid
  filename   String
  mimeType   String    @map("mime_type")
  size       Int
  bucket     String
  key        String
  url        String?
  entityType String?   @map("entity_type")
  entityId   String?   @map("entity_id") @db.Uuid
  uploadedBy String    @map("uploaded_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at")
  deletedAt  DateTime? @map("deleted_at")

  @@map("media_assets")
}


// === RIDER MODULE (CTX-002) ===

enum RiderStatus {
  PRE_REGISTERED
  DOCUMENTS_PENDING
  VERIFICATION_PENDING
  APPROVED
  AVAILABLE
  ASSIGNED
  CAMPAIGN_ACTIVE
  UNAVAILABLE
  SUSPENDED
}

enum DocumentStatus {
  UPLOADED
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
  REPLACEMENT_REQUIRED
}

model Rider {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @unique @map("user_id") @db.Uuid
  status          RiderStatus  @default(PRE_REGISTERED)
  fullName        String?      @map("full_name")
  dateOfBirth     DateTime?    @map("date_of_birth")
  address         String?
  emergencyName   String?      @map("emergency_name")
  emergencyPhone  String?      @map("emergency_phone")
  profilePhotoId  String?      @map("profile_photo_id") @db.Uuid
  zoneId          String?      @map("zone_id") @db.Uuid
  regionId        String?      @map("region_id") @db.Uuid
  reliabilityScore Int         @default(0) @map("reliability_score")
  totalCampaigns  Int          @default(0) @map("total_campaigns")
  totalEarnings   Int          @default(0) @map("total_earnings")
  suspensionReason String?     @map("suspension_reason")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  vehicle         RiderVehicle?
  documents       RiderDocument[]
  assets          RiderAsset[]
  reliabilityScores ReliabilityScore[]
  statusHistory   RiderStatusHistory[]

  @@map("rider_riders")
}

model RiderVehicle {
  id                 String   @id @default(uuid()) @db.Uuid
  riderId            String   @unique @map("rider_id") @db.Uuid
  vehicleType        String   @default("motorcycle") @map("vehicle_type")
  registrationNumber String   @map("registration_number")
  color              String?
  makeModel          String?  @map("make_model")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  rider Rider @relation(fields: [riderId], references: [id])

  @@map("rider_vehicles")
}

model RiderDocument {
  id            String         @id @default(uuid()) @db.Uuid
  riderId       String         @map("rider_id") @db.Uuid
  documentType  String         @map("document_type")
  mediaId       String         @map("media_id") @db.Uuid
  status        DocumentStatus @default(UPLOADED)
  rejectionReason String?      @map("rejection_reason")
  expiryDate    DateTime?      @map("expiry_date")
  reviewedBy    String?        @map("reviewed_by") @db.Uuid
  reviewedAt    DateTime?      @map("reviewed_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  rider Rider @relation(fields: [riderId], references: [id])

  @@map("rider_documents")
}

model RiderAsset {
  id           String   @id @default(uuid()) @db.Uuid
  riderId      String   @map("rider_id") @db.Uuid
  assetType    String   @default("helmet") @map("asset_type")
  description  String?
  isVerified   Boolean  @default(false) @map("is_verified")
  mediaId      String?  @map("media_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  rider Rider @relation(fields: [riderId], references: [id])

  @@map("rider_assets")
}

model ReliabilityScore {
  id              String   @id @default(uuid()) @db.Uuid
  riderId         String   @map("rider_id") @db.Uuid
  verification    Int      @default(0)
  attendance      Int      @default(0)
  activity        Int      @default(0)
  completion      Int      @default(0)
  response        Int      @default(0)
  compositeScore  Int      @default(0) @map("composite_score")
  computedAt      DateTime @default(now()) @map("computed_at")

  rider Rider @relation(fields: [riderId], references: [id])

  @@map("rider_reliability_scores")
}

model RiderStatusHistory {
  id         String      @id @default(uuid()) @db.Uuid
  riderId    String      @map("rider_id") @db.Uuid
  fromStatus RiderStatus @map("from_status")
  toStatus   RiderStatus @map("to_status")
  reason     String?
  changedBy  String?     @map("changed_by") @db.Uuid
  createdAt  DateTime    @default(now()) @map("created_at")

  rider Rider @relation(fields: [riderId], references: [id])

  @@map("rider_status_history")
}



// === BUSINESS MODULE (CTX-003) ===

enum BusinessStatus {
  REGISTERED
  DOCUMENTS_PENDING
  UNDER_REVIEW
  VERIFIED
  ACTIVE
  SUSPENDED
  BLACKLISTED
}

model Business {
  id                 String         @id @default(uuid()) @db.Uuid
  userId             String         @unique @map("user_id") @db.Uuid
  status             BusinessStatus @default(REGISTERED)
  companyName        String?        @map("company_name")
  legalName          String?        @map("legal_name")
  panVatNumber       String?        @map("pan_vat_number")
  address            String?
  phone              String?
  website            String?
  industry           String?
  contactPersonName  String?        @map("contact_person_name")
  contactPersonEmail String?        @map("contact_person_email")
  contactPersonPhone String?        @map("contact_person_phone")
  regionId           String?        @map("region_id") @db.Uuid
  zoneId             String?        @map("zone_id") @db.Uuid
  totalCampaigns     Int            @default(0) @map("total_campaigns")
  totalSpent         Int            @default(0) @map("total_spent")
  suspensionReason   String?        @map("suspension_reason")
  blacklistReason    String?        @map("blacklist_reason")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  deletedAt          DateTime?      @map("deleted_at")

  documents       BusinessDocument[]
  statusHistory   BusinessStatusHistory[]

  @@map("business_businesses")
}

model BusinessDocument {
  id              String         @id @default(uuid()) @db.Uuid
  businessId      String         @map("business_id") @db.Uuid
  documentType    String         @map("document_type")
  mediaId         String         @map("media_id") @db.Uuid
  status          DocumentStatus @default(UPLOADED)
  rejectionReason String?        @map("rejection_reason")
  reviewedBy      String?        @map("reviewed_by") @db.Uuid
  reviewedAt      DateTime?      @map("reviewed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id])

  @@map("business_documents")
}

model BusinessStatusHistory {
  id         String         @id @default(uuid()) @db.Uuid
  businessId String         @map("business_id") @db.Uuid
  fromStatus BusinessStatus @map("from_status")
  toStatus   BusinessStatus @map("to_status")
  reason     String?
  changedBy  String?        @map("changed_by") @db.Uuid
  createdAt  DateTime       @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id])

  @@map("business_status_history")
}



// === CAMPAIGN MODULE (CTX-004) ===

enum CampaignStatus {
  DRAFT
  PENDING_PAYMENT
  PAYMENT_SUBMITTED
  PAYMENT_VERIFIED
  RECRUITING_RIDERS
  READY
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
}

model Campaign {
  id                String         @id @default(uuid()) @db.Uuid
  businessId        String         @map("business_id") @db.Uuid
  name              String
  status            CampaignStatus @default(DRAFT)
  targetZones       String[]       @map("target_zones") @db.Uuid
  requiredRiders    Int            @map("required_riders")
  currentAssigned   Int            @default(0) @map("current_assigned")
  fulfillmentPct    Decimal        @default(0) @map("fulfillment_pct") @db.Decimal(5, 2)
  assetType         String         @default("helmet") @map("asset_type")
  startDate         DateTime       @map("start_date")
  endDate           DateTime       @map("end_date")
  durationDays      Int            @map("duration_days")
  totalCost         Int            @map("total_cost")
  dailyRate         Int            @map("daily_rate")
  riderDailyRate    Int            @map("rider_daily_rate")
  creativeMediaId   String?        @map("creative_media_id") @db.Uuid
  cancellationReason String?       @map("cancellation_reason")
  pauseReason       String?        @map("pause_reason")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  deletedAt         DateTime?      @map("deleted_at")

  assignments       Assignment[]
  statusHistory     CampaignStatusHistory[]
  payment           CampaignPayment?

  @@map("campaign_campaigns")
}

model CampaignPayment {
  id              String   @id @default(uuid()) @db.Uuid
  campaignId      String   @unique @map("campaign_id") @db.Uuid
  method          String
  amount          Int
  referenceId     String   @map("reference_id")
  paymentDate     DateTime @map("payment_date")
  proofMediaId    String   @map("proof_media_id") @db.Uuid
  status          String   @default("submitted")
  rejectionReason String?  @map("rejection_reason")
  verifiedBy      String?  @map("verified_by") @db.Uuid
  verifiedAt      DateTime? @map("verified_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@map("campaign_payments")
}

model CampaignStatusHistory {
  id         String         @id @default(uuid()) @db.Uuid
  campaignId String         @map("campaign_id") @db.Uuid
  fromStatus CampaignStatus @map("from_status")
  toStatus   CampaignStatus @map("to_status")
  reason     String?
  changedBy  String?        @map("changed_by") @db.Uuid
  createdAt  DateTime       @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@map("campaign_status_history")
}

// === ASSIGNMENT MODULE (CTX-005) ===

enum AssignmentStatus {
  SUGGESTED
  ASSIGNED
  STICKER_PENDING
  DISTRIBUTED
  INSTALLED
  ACTIVE
  COMPLETED
  REMOVED
}

model Assignment {
  id              String           @id @default(uuid()) @db.Uuid
  campaignId      String           @map("campaign_id") @db.Uuid
  riderId         String           @map("rider_id") @db.Uuid
  status          AssignmentStatus @default(ASSIGNED)
  zoneId          String?          @map("zone_id") @db.Uuid
  assignedBy      String?          @map("assigned_by") @db.Uuid
  startDate       DateTime?        @map("start_date")
  endDate         DateTime?        @map("end_date")
  daysCompleted   Int              @default(0) @map("days_completed")
  totalEarnings   Int              @default(0) @map("total_earnings")
  removalReason   String?          @map("removal_reason")
  removedBy       String?          @map("removed_by") @db.Uuid
  removedAt       DateTime?        @map("removed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, riderId])
  @@map("assignment_assignments")
}



// === FINANCIAL PLATFORM MODULE (CTX-007) ===

enum LedgerAccountType {
  ACCOUNTS_RECEIVABLE
  CAMPAIGN_ESCROW
  PLATFORM_REVENUE
  RIDER_LIABILITY
  RIDER_PAYOUT
}

enum LedgerEntryType {
  DEBIT
  CREDIT
}

model LedgerEntry {
  id            String           @id @default(uuid()) @db.Uuid
  accountType   LedgerAccountType @map("account_type")
  entryType     LedgerEntryType  @map("entry_type")
  amount        Int              // in paisa (NPR × 100)
  currency      String           @default("NPR")
  description   String
  referenceType String?          @map("reference_type") // campaign, assignment, payout
  referenceId   String?          @map("reference_id") @db.Uuid
  balanceAfter  Int?             @map("balance_after") // derived snapshot (optional)
  createdAt     DateTime         @default(now()) @map("created_at")
  createdBy     String?          @map("created_by") @db.Uuid

  // IMMUTABLE: No updatedAt — ledger entries cannot be modified
  @@map("finance_ledger_entries")
}

model Escrow {
  id              String   @id @default(uuid()) @db.Uuid
  campaignId      String   @unique @map("campaign_id") @db.Uuid
  totalAmount     Int      @map("total_amount") // in paisa
  releasedAmount  Int      @default(0) @map("released_amount")
  refundedAmount  Int      @default(0) @map("refunded_amount")
  remainingAmount Int      @map("remaining_amount") // computed: total - released - refunded
  totalDays       Int      @map("total_days")
  dailyRelease    Int      @map("daily_release") // total / days
  daysReleased    Int      @default(0) @map("days_released")
  status          String   @default("active") // active, completed, refunded, cancelled
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  closedAt        DateTime? @map("closed_at")

  releases EscrowRelease[]

  @@map("finance_escrows")
}

model EscrowRelease {
  id         String   @id @default(uuid()) @db.Uuid
  escrowId   String   @map("escrow_id") @db.Uuid
  dayNumber  Int      @map("day_number")
  amount     Int      // daily release amount in paisa
  commission Int      // platform commission portion
  riderShare Int      @map("rider_share") // rider portion
  releasedAt DateTime @default(now()) @map("released_at")

  escrow Escrow @relation(fields: [escrowId], references: [id])

  @@unique([escrowId, dayNumber])
  @@map("finance_escrow_releases")
}

model RiderWallet {
  id           String   @id @default(uuid()) @db.Uuid
  riderId      String   @unique @map("rider_id") @db.Uuid
  balance      Int      @default(0) // in paisa — derived from transactions
  totalEarned  Int      @default(0) @map("total_earned")
  totalPaidOut Int      @default(0) @map("total_paid_out")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  transactions WalletTransaction[]

  @@map("finance_rider_wallets")
}

model WalletTransaction {
  id          String   @id @default(uuid()) @db.Uuid
  walletId    String   @map("wallet_id") @db.Uuid
  type        String   // credit (earning) or debit (payout)
  amount      Int      // in paisa
  description String
  referenceType String? @map("reference_type") // assignment, payout_batch
  referenceId String?  @map("reference_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  wallet RiderWallet @relation(fields: [walletId], references: [id])

  @@map("finance_wallet_transactions")
}

model PayoutBatch {
  id           String   @id @default(uuid()) @db.Uuid
  cycleDate    DateTime @map("cycle_date")
  riderCount   Int      @map("rider_count")
  totalAmount  Int      @map("total_amount") // sum of all items in paisa
  status       String   @default("generated") // generated, approved, processing, completed, failed
  generatedBy  String?  @map("generated_by") @db.Uuid
  approvedBy   String?  @map("approved_by") @db.Uuid
  approvedAt   DateTime? @map("approved_at")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  items PayoutItem[]

  @@map("finance_payout_batches")
}

model PayoutItem {
  id            String   @id @default(uuid()) @db.Uuid
  batchId       String   @map("batch_id") @db.Uuid
  riderId       String   @map("rider_id") @db.Uuid
  walletId      String   @map("wallet_id") @db.Uuid
  amount        Int      // in paisa
  method        String   // esewa, khalti, bank_transfer, ime_pay
  accountDetail String?  @map("account_detail") // masked account info
  status        String   @default("pending") // pending, completed, failed
  proofMediaId  String?  @map("proof_media_id") @db.Uuid
  referenceId   String?  @map("reference_id") // external transaction ref
  completedAt   DateTime? @map("completed_at")
  failureReason String?  @map("failure_reason")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  batch PayoutBatch @relation(fields: [batchId], references: [id])

  @@map("finance_payout_items")
}

model Invoice {
  id            String   @id @default(uuid()) @db.Uuid
  invoiceNumber String   @unique @map("invoice_number")
  businessId    String   @map("business_id") @db.Uuid
  campaignId    String   @map("campaign_id") @db.Uuid
  amount        Int      // in paisa
  taxAmount     Int      @default(0) @map("tax_amount")
  totalAmount   Int      @map("total_amount")
  status        String   @default("issued") // issued, paid
  issuedAt      DateTime @default(now()) @map("issued_at")
  paidAt        DateTime? @map("paid_at")
  lineItems     Json     @map("line_items") // [{description, qty, rate, amount}]
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("finance_invoices")
}



// === NOTIFICATION MODULE (CTX-008) ===

model Notification {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  title       String
  body        String
  type        String   // assignment, verification, payout, document, campaign, support, system
  channel     String   // push, in_app
  templateId  String?  @map("template_id") @db.Uuid
  deepLink    String?  @map("deep_link")
  isRead      Boolean  @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notification_notifications")
}

model NotificationTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  code        String
  version     Int      @default(1)
  channel     String   // push, in_app, sms
  language    String   @default("en")
  title       String
  body        String
  variables   String[] // declared variable names
  isActive    Boolean  @default(true) @map("is_active")
  createdBy   String?  @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([code, version, channel, language])
  @@map("notification_templates")
}

model NotificationPreference {
  id       String  @id @default(uuid()) @db.Uuid
  userId   String  @map("user_id") @db.Uuid
  category String  // assignment, verification, payout, document, campaign, support, system
  push     Boolean @default(true)
  inApp    Boolean @default(true) @map("in_app")

  @@unique([userId, category])
  @@map("notification_preferences")
}

// === TIMELINE MODULE (CTX-011) ===

model TimelineEntry {
  id          String   @id @default(uuid()) @db.Uuid
  entityType  String   @map("entity_type") // rider, business, campaign, assignment
  entityId    String   @map("entity_id") @db.Uuid
  eventType   String   @map("event_type")
  title       String
  description String?
  actorId     String?  @map("actor_id") @db.Uuid
  actorRole   String?  @map("actor_role")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId, createdAt])
  @@map("timeline_entries")
}

// === ANALYTICS MODULE (CTX-014) ===

model MetricSnapshot {
  id        String   @id @default(uuid()) @db.Uuid
  metric    String   // active_riders, active_campaigns, total_revenue, etc.
  value     Decimal  @db.Decimal(15, 2)
  dimension String?  // zone, channel, category (for dimensional metrics)
  dimensionValue String? @map("dimension_value")
  period    String   @default("daily") // hourly, daily, weekly, monthly
  periodStart DateTime @map("period_start")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([metric, periodStart])
  @@index([metric, dimension, periodStart])
  @@map("analytics_metric_snapshots")
}

model AnalyticsEvent {
  id         String   @id @default(uuid()) @db.Uuid
  eventType  String   @map("event_type")
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id") @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  properties Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([eventType, createdAt])
  @@map("analytics_events")
}
