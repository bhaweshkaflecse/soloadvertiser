// Prisma Schema — Solo Advertiser
// Sprint 1: Identity, Configuration, and Media models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === IDENTITY MODULE (CTX-001) ===

enum Role {
  SUPER_ADMIN
  ADMIN
  OPERATIONS_STAFF
  FINANCE_STAFF
  BUSINESS
  RIDER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

model User {
  id             String     @id @default(uuid()) @db.Uuid
  email          String?    @unique
  phone          String?    @unique
  passwordHash   String?    @map("password_hash")
  role           Role       @default(RIDER)
  status         UserStatus @default(ACTIVE)
  emailVerified  Boolean    @default(false) @map("email_verified")
  phoneVerified  Boolean    @default(false) @map("phone_verified")
  failedAttempts Int        @default(0) @map("failed_attempts")
  lockedUntil    DateTime?  @map("locked_until")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  sessions Session[]

  @@map("identity_users")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  deviceInfo   String?  @map("device_info")
  ipAddress    String?  @map("ip_address")
  refreshToken String   @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("identity_sessions")
}

// === CONFIGURATION MODULE (CTX-009) ===

model ConfigEntry {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  value       Json
  category    String
  description String?
  dataType    String   @map("data_type")
  updatedBy   String?  @map("updated_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("config_entries")
}

model FeatureFlag {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?
  updatedBy   String?  @map("updated_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("config_feature_flags")
}

model DictionaryItem {
  id          String   @id @default(uuid()) @db.Uuid
  dictionary  String
  code        String
  label       String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  metadata    Json?
  regionId    String?  @map("region_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([dictionary, code])
  @@map("config_dictionary_items")
}

// === MEDIA MODULE (CTX-012) ===

model MediaAsset {
  id         String    @id @default(uuid()) @db.Uuid
  filename   String
  mimeType   String    @map("mime_type")
  size       Int
  bucket     String
  key        String
  url        String?
  entityType String?   @map("entity_type")
  entityId   String?   @map("entity_id") @db.Uuid
  uploadedBy String    @map("uploaded_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at")
  deletedAt  DateTime? @map("deleted_at")

  @@map("media_assets")
}


// === RIDER MODULE (CTX-002) ===

enum RiderStatus {
  PRE_REGISTERED
  DOCUMENTS_PENDING
  VERIFICATION_PENDING
  APPROVED
  AVAILABLE
  ASSIGNED
  CAMPAIGN_ACTIVE
  UNAVAILABLE
  SUSPENDED
}

enum DocumentStatus {
  UPLOADED
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
  REPLACEMENT_REQUIRED
}

model Rider {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @unique @map("user_id") @db.Uuid
  status          RiderStatus  @default(PRE_REGISTERED)
  fullName        String?      @map("full_name")
  dateOfBirth     DateTime?    @map("date_of_birth")
  address         String?
  emergencyName   String?      @map("emergency_name")
  emergencyPhone  String?      @map("emergency_phone")
  profilePhotoId  String?      @map("profile_photo_id") @db.Uuid
  zoneId          String?      @map("zone_id") @db.Uuid
  regionId        String?      @map("region_id") @db.Uuid
  reliabilityScore Int         @default(0) @map("reliability_score")
  totalCampaigns  Int          @default(0) @map("total_campaigns")
  totalEarnings   Int          @default(0) @map("total_earnings")
  suspensionReason String?     @map("suspension_reason")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  vehicle         RiderVehicle?
  documents       RiderDocument[]
  assets          RiderAsset[]
  reliabilityScores ReliabilityScore[]
  statusHistory   RiderStatusHistory[]

  @@map("rider_riders")
}

model RiderVehicle {
  id                 String   @id @default(uuid()) @db.Uuid
  riderId            String   @unique @map("rider_id") @db.Uuid
  vehicleType        String   @default("motorcycle") @map("vehicle_type")
  registrationNumber String   @map("registration_number")
  color              String?
  makeModel          String?  @map("make_model")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  rider Rider @relation(fields: [riderId], references: [id])

  @@map("rider_vehicles")
}

model RiderDocument {
  id            String         @id @default(uuid()) @db.Uuid
  riderId       String         @map("rider_id") @db.Uuid
  documentType  String         @map("document_type")
  mediaId       String         @map("media_id") @db.Uuid
  status        DocumentStatus @default(UPLOADED)
  rejectionReason String?      @map("rejection_reason")
  expiryDate    DateTime?      @map("expiry_date")
  reviewedBy    String?        @map("reviewed_by") @db.Uuid
  reviewedAt    DateTime?      @map("reviewed_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  rider Rider @relation(fields: [riderId], references: [id])

  @@map("rider_documents")
}

model RiderAsset {
  id           String   @id @default(uuid()) @db.Uuid
  riderId      String   @map("rider_id") @db.Uuid
  assetType    String   @default("helmet") @map("asset_type")
  description  String?
  isVerified   Boolean  @default(false) @map("is_verified")
  mediaId      String?  @map("media_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  rider Rider @relation(fields: [riderId], references: [id])

  @@map("rider_assets")
}

model ReliabilityScore {
  id              String   @id @default(uuid()) @db.Uuid
  riderId         String   @map("rider_id") @db.Uuid
  verification    Int      @default(0)
  attendance      Int      @default(0)
  activity        Int      @default(0)
  completion      Int      @default(0)
  response        Int      @default(0)
  compositeScore  Int      @default(0) @map("composite_score")
  computedAt      DateTime @default(now()) @map("computed_at")

  rider Rider @relation(fields: [riderId], references: [id])

  @@map("rider_reliability_scores")
}

model RiderStatusHistory {
  id         String      @id @default(uuid()) @db.Uuid
  riderId    String      @map("rider_id") @db.Uuid
  fromStatus RiderStatus @map("from_status")
  toStatus   RiderStatus @map("to_status")
  reason     String?
  changedBy  String?     @map("changed_by") @db.Uuid
  createdAt  DateTime    @default(now()) @map("created_at")

  rider Rider @relation(fields: [riderId], references: [id])

  @@map("rider_status_history")
}
