{
  "name": "soloadvertiser",
  "version": "0.0.0",
  "private": true,
  "description": "Solo Advertiser — Advertising Inventory Marketplace",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @soloadvertiser/database exec prisma generate",
    "db:migrate": "pnpm --filter @soloadvertiser/database exec prisma migrate dev",
    "db:studio": "pnpm --filter @soloadvertiser/database exec prisma studio",
    "db:seed": "pnpm --filter @soloadvertiser/database exec prisma db seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "prettier": "^3.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
